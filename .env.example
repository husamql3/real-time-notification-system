# Neon database — auto-provisioned by vite-plugin-neon-new during `bun dev`,
# or set manually for production.
DATABASE_URL=
DATABASE_URL_DIRECT=

# Better Auth
BETTER_AUTH_SECRET=                        # generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000      # set to your production URL when deploying

# Admin user (matched against session email; also used by `bun db:seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
